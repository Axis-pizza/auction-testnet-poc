# Select the RPC profile. Testnet SOL and Devnet SOL are separate.
AXIS_CLUSTER=localnet
# Optional override for a private RPC endpoint. Never put an API key in a committed .env file.
# AXIS_RPC_URL=http://127.0.0.1:8899

# Required signing wallet path. This value is a file path only; the scripts never print key material.
ANCHOR_WALLET=~/.config/solana/id.json
# Program identity is read exclusively from target/idl/axis_auction.json.
# Before deploy, synchronize declare_id! and the deployment program keypair.

# Scenario inputs. usdc_mint is an accounting label only in the current record-only POC;
# no SPL token account or transfer is created.
AXIS_USDC_MINT=11111111111111111111111111111111
AXIS_MARKET_ID=1001
AXIS_ROUND_INDEX=0
AXIS_AUCTION_DURATION_SLOTS=3
AXIS_BIDS=1000000,1750000

# Config / market defaults used by the scenario scripts.
AXIS_PROTOCOL_FEE_BPS=2000
AXIS_DEFAULT_AUCTION_DURATION_SLOTS=3
AXIS_MIN_BID_AMOUNT=1000000
AXIS_MIN_IMPROVEMENT_BPS=7500
AXIS_BATCH_SIZE=1000000000
AXIS_PRE_NAV=1000000
AXIS_TARGET_NAV=1050000
AXIS_MOCK_POOL_PRICE=1040000
AXIS_EXPECTED_COST_WITHOUT_AUCTION=50000000
AXIS_MAX_NAV_STALENESS_SLOTS=10000
AXIS_MIN_SETTLEMENT_OUT=1000000
AXIS_MARKET_MIN_IMPROVEMENT_BPS=7500

# Optional priority fee. Set both values to request a priority fee.
AXIS_PRIORITY_FEE_MICRO_LAMPORTS=0
AXIS_COMPUTE_UNIT_LIMIT=200000
AXIS_COMMITMENT=confirmed
